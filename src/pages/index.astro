---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/astro/Header.astro';
import Hero from '../components/astro/Hero.astro';
import MenuFilter from '../components/react/MenuFilter';
import MenuGrid from '../components/astro/MenuGrid.astro';
import ContactSection from '../components/astro/ContactSection.astro';
import MapSection from '../components/astro/MapSection.astro';
import Footer from '../components/astro/Footer.astro';

import { categories } from '../data/categories';
import { products } from '../data/products';
import '../styles/global.css';

const title = 'Restaurante Nueva Muralla - Comida China Auténtica en Madrid';
const description = 'Restaurante chino en Madrid. Descubre nuestro menú de comida china auténtica con los mejores platos tradicionales. Llámanos para reservar.';
---

<BaseLayout title={title} description={description}>
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-accent focus:text-dark focus:px-4 focus:py-2 focus:rounded focus:font-semibold"
  >
    Saltar al contenido principal
  </a>

  <Header />

  <main id="main-content">
    <Hero />

    <!-- About Section
    <section id="nosotros" class="relative py-24 bg-dark overflow-hidden">
      <div class="absolute inset-0 opacity-[0.02]" style="background-image: radial-gradient(circle at 1px 1px, #d4a017 1px, transparent 0); background-size: 40px 40px;"></div>
      <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
        <p class="text-accent/80 text-xs uppercase tracking-[0.3em] mb-4 font-sans font-medium">Sobre Nosotros</p>
        <h2 class="section-title mb-4">Tradición y Sabor</h2>
        <div class="gold-divider mb-10">
          <span class="text-accent text-xl font-serif">味</span>
        </div>
        <p class="text-white/50 text-lg leading-relaxed max-w-3xl mx-auto mb-6">
          En Restaurante Nueva Muralla llevamos años ofreciendo la auténtica cocina china en el corazón de Madrid. Nuestros chefs, con décadas de experiencia, preparan cada plato con ingredientes frescos y recetas tradicionales transmitidas de generación en generación.
        </p>
        <p class="text-white/35 text-base leading-relaxed max-w-2xl mx-auto">
          Desde nuestros crujientes rollitos de primavera hasta el exquisito pato pekinés, cada bocado es un viaje al corazón de la gastronomía china.
        </p>
      </div>
    </section> -->

    <!-- Menu Section -->
    <section id="menu" class="relative py-24 bg-dark-gray" aria-label="Nuestra carta">
      <div class="max-w-7xl mx-auto px-4">
        <p class="text-accent/80 text-xs uppercase tracking-[0.3em] text-center mb-4 font-sans font-medium">Nuestra Carta</p>
        <h2 class="section-title mb-4">El Menú</h2>
        <div class="gold-divider mb-12">
          <span class="text-accent text-xl font-serif">新</span>
        </div>
      </div>

      <MenuFilter categories={categories} client:load />
      <MenuGrid products={products} />
    </section>

    <ContactSection />
    <MapSection />
  </main>

  <Footer />
</BaseLayout>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
