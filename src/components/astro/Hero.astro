---
import { contactInfo } from '../../data/contact';
---

<section id="inicio" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Dark gradient background with subtle red glow -->
  <div class="absolute inset-0 bg-gradient-to-b from-dark via-dark-gray to-dark"></div>

  <!-- Subtle decorative pattern overlay -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, #d4a017 1px, transparent 0); background-size: 40px 40px;"></div>

  <!-- Red glow from top -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-primary/10 blur-[150px] rounded-full"></div>

  <!-- Gold accent lines -->
  <div class="absolute top-20 left-0 w-full h-px bg-gradient-to-r from-transparent via-accent/20 to-transparent"></div>
  <div class="absolute bottom-20 left-0 w-full h-px bg-gradient-to-r from-transparent via-accent/20 to-transparent"></div>

  <!-- Decorative Chinese characters -->
  <div class="absolute top-1/4 left-[5%] text-accent/[0.04] text-[200px] font-serif leading-none select-none" aria-hidden="true">味</div>
  <div class="absolute bottom-1/4 right-[5%] text-accent/[0.04] text-[200px] font-serif leading-none select-none" aria-hidden="true">香</div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto px-4 text-center">
    <!-- Small top label -->
    <p class="text-accent/80 text-xs sm:text-sm uppercase tracking-[0.3em] mb-8 animate-fade-in font-sans font-medium">
      Auténtica Cocina China en Madrid
    </p>

    <!-- Main title -->
    <h1 class="font-display text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-bold text-white mb-4 animate-fade-in" style="animation-delay: 0.15s; opacity:0;">
      Nueva Muralla
    </h1>

    <!-- Gold divider -->
    <div class="gold-divider animate-fade-in" style="animation-delay: 0.3s; opacity:0;">
      <span class="text-accent text-2xl font-serif">新</span>
    </div>

    <!-- Subtitle -->
    <p class="text-white/60 text-base sm:text-lg md:text-xl max-w-2xl mx-auto mb-12 animate-fade-in font-light leading-relaxed" style="animation-delay: 0.45s; opacity:0;">
      Sabores milenarios, ingredientes frescos y recetas transmitidas de generación en generación. Una experiencia gastronómica que te transporta al corazón de China.
    </p>

    <!-- CTA buttons -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center animate-fade-in" style="animation-delay: 0.6s; opacity:0;">
      <a
        href="#menu"
        class="btn-accent w-full sm:w-auto text-center min-h-[48px] flex items-center justify-center gap-2"
      >
        Ver Nuestra Carta
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
      </a>
      <a
        href={`tel:${contactInfo.telefono.replace(/\s/g, '')}`}
        class="btn-outline w-full sm:w-auto text-center min-h-[48px] flex items-center justify-center gap-2"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        Reservar Mesa
      </a>
    </div>

    <!-- Hours -->
    <p class="text-white/30 text-sm mt-12 animate-fade-in font-sans" style="animation-delay: 0.75s; opacity:0;">
      Lun, Mié–Dom: 11:30–16:30 y 19:30–23:30 &nbsp;·&nbsp; Martes cerrado
    </p>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-5 h-5 text-accent/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
  </div>
</section>
