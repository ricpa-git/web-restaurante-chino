---
import { contactInfo } from '../../data/contact';
---

<section id="contacto" class="relative py-24 overflow-hidden" aria-label="Información de contacto">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-dark via-primary/[0.08] to-dark"></div>
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: radial-gradient(circle at 1px 1px, #d4a017 1px, transparent 0); background-size: 40px 40px;"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-4">
    <!-- Section Header -->
    <p class="text-accent/80 text-xs uppercase tracking-[0.3em] text-center mb-4 font-sans font-medium">Contacto</p>
    <h2 class="section-title mb-4">Visítanos</h2>
    <div class="gold-divider mb-16">
      <span class="text-accent text-xl font-serif">新</span>
    </div>

    <!-- Contact Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-16">
      <!-- Phone -->
      <div class="bg-dark-gray/60 border border-white/5 p-8 text-center group hover:border-accent/30 transition-all duration-500">
        <div class="w-14 h-14 border border-accent/30 rounded-full flex items-center justify-center mx-auto mb-5 group-hover:border-accent transition-colors duration-300">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
        </div>
        <h3 class="text-white font-display text-lg mb-2">Teléfono</h3>
        <a
          href={`tel:${contactInfo.telefono.replace(/\s/g, '')}`}
          class="text-accent hover:text-accent-light transition-colors text-base"
        >
          {contactInfo.telefono}
        </a>
      </div>

      <!-- Hours -->
      <div class="bg-dark-gray/60 border border-white/5 p-8 text-center group hover:border-accent/30 transition-all duration-500">
        <div class="w-14 h-14 border border-accent/30 rounded-full flex items-center justify-center mx-auto mb-5 group-hover:border-accent transition-colors duration-300">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <h3 class="text-white font-display text-lg mb-2">Horario</h3>
        <div class="text-sm leading-relaxed space-y-1">
          <p class="text-white/50">Lun, Mié–Dom</p>
          <p class="text-white/70">11:30–16:30 · 19:30–23:30</p>
          <p class="text-primary/80 mt-2">Martes: Cerrado</p>
        </div>
      </div>

      <!-- Address -->
      <div class="bg-dark-gray/60 border border-white/5 p-8 text-center group hover:border-accent/30 transition-all duration-500">
        <div class="w-14 h-14 border border-accent/30 rounded-full flex items-center justify-center mx-auto mb-5 group-hover:border-accent transition-colors duration-300">
          <svg class="w-6 h-6 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <h3 class="text-white font-display text-lg mb-2">Dirección</h3>
        <p class="text-white/50 text-sm leading-relaxed">{contactInfo.direccion}</p>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center border border-accent/20 bg-accent/[0.03] p-10 md:p-14">
      <h3 class="text-2xl md:text-3xl font-display font-bold text-white mb-3">
        ¿Listo para una experiencia única?
      </h3>
      <p class="text-white/40 text-base mb-8 max-w-xl mx-auto">
        Reserva tu mesa o haz tu pedido. Te esperamos con los mejores sabores de China.
      </p>
      <a
        href={`tel:${contactInfo.telefono.replace(/\s/g, '')}`}
        class="btn-accent inline-flex items-center gap-2 min-h-[48px]"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
        </svg>
        Llámanos Ahora
      </a>
    </div>
  </div>
</section>
