---
import type { Product } from '../../types';

interface Props {
  product: Product;
  index?: number;
}

const { product, index: _index } = Astro.props;
---

<div
  class="product-card group relative bg-dark-gray border border-white/5 p-5 hover:border-accent/30 transition-all duration-500"
  data-category={product.categoriaId}
>
  <!-- Gold corner on hover -->
  <div class="absolute top-0 right-0 w-8 h-8 opacity-0 group-hover:opacity-100 transition-opacity duration-500">
    <div class="absolute top-0 right-0 w-full h-px bg-accent/60"></div>
    <div class="absolute top-0 right-0 h-full w-px bg-accent/60"></div>
  </div>

  <h3 class="font-display text-base text-white group-hover:text-accent transition-colors duration-300 mb-1">
    {product.nombre}
  </h3>

  {product.descripcion && (
    <p class="text-white/35 text-sm font-light italic">
      {product.descripcion}
    </p>
  )}
</div>
